---
interface Props {
  about: {
    name: string;
    email: string;
    linkedin?: string;
    phone?: string;
  };
}
const { about } = Astro.props;
---

<section id="contact" class="py-28 px-6 bg-[#10141f]">
  <div class="max-w-6xl mx-auto">

    <div class="flex items-center gap-4 mb-16 reveal">
      <span class="font-['JetBrains_Mono'] text-[10px] tracking-[0.35em] text-[#e8a030] uppercase">04 — Contact</span>
      <div class="flex-1 h-px bg-[#1e2535]"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-16 items-center">

      <div class="reveal">
        <h2 class="font-['Bebas_Neue'] text-[clamp(2rem,5vw,3.5rem)] text-white leading-tight tracking-wide mb-4">
          Ready to<br/><span class="text-[#e8a030]">Begin the Approach</span>
        </h2>
        <p class="font-['Crimson_Pro'] text-lg text-[#c8cdd8]/70 leading-relaxed">
          Open to opportunities across commercial aviation. Whether you're looking for an experienced captain, a training captain, or a first officer — let's talk.
        </p>
      </div>

      <div class="reveal space-y-4" style="transition-delay: 0.15s">

        <a
          href={`mailto:${about.email}`}
          class="group flex items-center gap-5 p-5 border border-[#1e2535] hover:border-[#e8a030]/40 transition-colors"
        >
          <div class="w-10 h-10 border border-[#1e2535] group-hover:border-[#e8a030]/40 flex items-center justify-center transition-colors flex-shrink-0">
            <svg class="w-4 h-4 text-[#e8a030]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <p class="font-['JetBrains_Mono'] text-[10px] tracking-widest text-[#5a6278] uppercase mb-0.5">Email</p>
            <p class="font-['Crimson_Pro'] text-[#c8cdd8] group-hover:text-[#e8a030] transition-colors">{about.email}</p>
          </div>
        </a>

        {about.linkedin && (
          <a
            href={about.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-5 p-5 border border-[#1e2535] hover:border-[#e8a030]/40 transition-colors"
          >
            <div class="w-10 h-10 border border-[#1e2535] group-hover:border-[#e8a030]/40 flex items-center justify-center transition-colors flex-shrink-0">
              <svg class="w-4 h-4 text-[#e8a030]" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </div>
            <div>
              <p class="font-['JetBrains_Mono'] text-[10px] tracking-widest text-[#5a6278] uppercase mb-0.5">LinkedIn</p>
              <p class="font-['Crimson_Pro'] text-[#c8cdd8] group-hover:text-[#e8a030] transition-colors">View Profile</p>
            </div>
          </a>
        )}

        {about.phone && (
          <a
            href={`tel:${about.phone}`}
            class="group flex items-center gap-5 p-5 border border-[#1e2535] hover:border-[#e8a030]/40 transition-colors"
          >
            <div class="w-10 h-10 border border-[#1e2535] group-hover:border-[#e8a030]/40 flex items-center justify-center transition-colors flex-shrink-0">
              <svg class="w-4 h-4 text-[#e8a030]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <div>
              <p class="font-['JetBrains_Mono'] text-[10px] tracking-widest text-[#5a6278] uppercase mb-0.5">Phone</p>
              <p class="font-['Crimson_Pro'] text-[#c8cdd8] group-hover:text-[#e8a030] transition-colors">{about.phone}</p>
            </div>
          </a>
        )}

      </div>
    </div>
  </div>
</section>
