---
interface Recommendation {
  author: string;
  role: string;
  company: string;
  text: string;
}
interface Props { items: Recommendation[]; }
const { items } = Astro.props;
---

<section id="recommendations" class="py-28 px-6">
  <div class="max-w-6xl mx-auto">

    <div class="flex items-center gap-4 mb-16 reveal">
      <span class="font-['JetBrains_Mono'] text-[10px] tracking-[0.35em] text-[#e8a030] uppercase">03 — Recommendations</span>
      <div class="flex-1 h-px bg-[#1e2535]"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      {items.map((item, i) => (
        <figure
          class="reveal border border-[#1e2535] bg-[#10141f] p-8 flex flex-col gap-6 hover:border-[#e8a030]/20 transition-colors"
          style={`transition-delay: ${i * 0.1}s`}
        >
          <!-- Large decorative quote mark -->
          <div class="font-['Bebas_Neue'] text-7xl text-[#e8a030]/15 leading-none select-none -mb-4">"</div>

          <blockquote class="font-['Crimson_Pro'] text-lg leading-relaxed text-[#c8cdd8]/80 italic flex-1">
            {item.text}
          </blockquote>

          <figcaption class="pt-4 border-t border-[#1e2535]">
            <p class="font-['Bebas_Neue'] text-lg text-white tracking-wide">{item.author}</p>
            <p class="font-['JetBrains_Mono'] text-[10px] tracking-widest text-[#5a6278] uppercase mt-0.5">
              {item.role} · {item.company}
            </p>
          </figcaption>
        </figure>
      ))}
    </div>

  </div>
</section>
