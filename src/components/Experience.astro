---
interface ExperienceItem {
  role: string;
  company: string;
  period: string;
  aircraft?: string;
  highlights: string[];
}
interface Props { items: ExperienceItem[]; }
const { items } = Astro.props;
---

<section id="experience" class="py-28 px-6 bg-[#10141f]">
  <div class="max-w-6xl mx-auto">

    <div class="flex items-center gap-4 mb-16 reveal">
      <span class="font-['JetBrains_Mono'] text-[10px] tracking-[0.35em] text-[#e8a030] uppercase">02 — Experience</span>
      <div class="flex-1 h-px bg-[#1e2535]"></div>
    </div>

    <div class="relative">
      <!-- Vertical timeline rule -->
      <div class="absolute left-0 top-0 bottom-0 w-px bg-[#1e2535] hidden md:block"></div>

      <div class="space-y-12">
        {items.map((item, i) => (
          <div class="reveal md:pl-10 relative" style={`transition-delay: ${i * 0.1}s`}>
            <!-- Timeline dot -->
            <div class="hidden md:block absolute left-0 top-1 w-2 h-2 rounded-full bg-[#e8a030] -translate-x-[calc(50%+0.5px)]"></div>

            <div class="border border-[#1e2535] bg-[#0a0d14] p-6 hover:border-[#e8a030]/30 transition-colors">
              <div class="flex flex-wrap items-start justify-between gap-3 mb-4">
                <div>
                  <h3 class="font-['Bebas_Neue'] text-2xl text-white tracking-wide">{item.role}</h3>
                  <p class="font-['Crimson_Pro'] italic text-[#e8a030]">{item.company}</p>
                </div>
                <div class="text-right">
                  <p class="font-['JetBrains_Mono'] text-xs text-[#5a6278] tracking-wider">{item.period}</p>
                  {item.aircraft && (
                    <p class="font-['JetBrains_Mono'] text-xs text-[#e8a030]/70 tracking-wider mt-1">{item.aircraft}</p>
                  )}
                </div>
              </div>

              <ul class="space-y-2">
                {item.highlights.map(h => (
                  <li class="flex items-start gap-3 font-['Crimson_Pro'] text-[#c8cdd8]/70">
                    <span class="text-[#e8a030] mt-1 flex-shrink-0">—</span>
                    <span>{h}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
