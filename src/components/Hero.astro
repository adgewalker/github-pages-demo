---
interface Props {
  about: {
    name: string;
    title: string;
    summary: string;
    heroImage?: string;
  };
}
const { about } = Astro.props;
const [firstName, ...rest] = about.name.split(' ');
const lastName = rest.join(' ');
---

<section
  id="hero"
  class="relative min-h-screen flex items-end overflow-hidden"
>
  <!-- Background image -->
  <div
    class="absolute inset-0 bg-cover bg-center bg-no-repeat"
    style={`background-image: url('${about.heroImage ?? '/images/hero.jpg'}')`}
  >
    <!-- Multi-layer overlay for drama and legibility -->
    <div class="absolute inset-0 bg-gradient-to-t from-[#0a0d14] via-[#0a0d14]/60 to-[#0a0d14]/20"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-[#0a0d14]/80 via-transparent to-transparent"></div>
  </div>

  <!-- Decorative rule lines — instrument panel feel -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#e8a030]/30 to-transparent"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-6xl mx-auto px-6 pb-24 pt-32 w-full">
    <!-- Pre-label -->
    <p class="font-['JetBrains_Mono'] text-xs tracking-[0.3em] text-[#e8a030] uppercase mb-6 animate-[fadeUp_0.8s_ease_0.2s_both]">
      Available for new opportunities
    </p>

    <!-- Name -->
    <h1 class="font-['Bebas_Neue'] leading-none mb-4 animate-[fadeUp_0.8s_ease_0.4s_both]">
      <span class="block text-[clamp(3.5rem,10vw,8rem)] text-white tracking-wide">{firstName}</span>
      <span class="block text-[clamp(3.5rem,10vw,8rem)] text-[#e8a030] tracking-wide">{lastName}</span>
    </h1>

    <!-- Title -->
    <p class="font-['Crimson_Pro'] italic text-[clamp(1.1rem,2.5vw,1.5rem)] text-[#c8cdd8]/80 mb-8 max-w-xl animate-[fadeUp_0.8s_ease_0.6s_both]">
      {about.title}
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-wrap gap-4 animate-[fadeUp_0.8s_ease_0.8s_both]">
      <a
        href="#about"
        class="inline-flex items-center gap-2 px-6 py-3 bg-[#e8a030] text-[#0a0d14] font-['JetBrains_Mono'] text-xs tracking-widest uppercase font-medium hover:bg-white transition-colors"
      >
        View Profile
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </a>
      <a
        href="#contact"
        class="inline-flex items-center gap-2 px-6 py-3 border border-[#1e2535] text-[#c8cdd8] font-['JetBrains_Mono'] text-xs tracking-widest uppercase hover:border-[#e8a030] hover:text-[#e8a030] transition-colors"
      >
        Get in Touch
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 right-8 flex flex-col items-center gap-2 animate-[fadeUp_0.8s_ease_1s_both]">
    <span class="font-['JetBrains_Mono'] text-[10px] tracking-widest text-[#5a6278] uppercase" style="writing-mode: vertical-rl;">Scroll</span>
    <div class="w-px h-12 bg-gradient-to-b from-[#5a6278] to-transparent"></div>
  </div>
</section>

<style>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: none; }
  }
</style>
